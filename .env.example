# PostgreSQL 연결 (Vercel 배포 시 Storage→Neon 에서 자동으로 채워짐)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- 선택적(optional) 환경 변수 ---
# ANTHROPIC_API_KEY 가 있으면 백엔드에서 진짜 Claude API 호출
# 없으면(기본) 묣료 모델 게이트웨이 사용 (키 불필요)
ANTHROPIC_API_KEY=

# POLLINATIONS_API_KEY 가 있으면 유료 고성능 모델(gpt-5.6-sol 등) 매핑
# 없으면 묣료 익명 모델 사용
POLLINATIONS_API_KEY=
