{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/chat",
      "headers": [
        {
          "key": "x-accelbuffering",
          "value": "no"
        }
      ]
    }
  ]
}
